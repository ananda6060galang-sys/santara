  void onInit() {

    super.onInit();

    final String?
        selectedCategory =

            Get.arguments
                as String?;

    if (selectedCategory != null) {

      final index =
          categories.indexOf(
              selectedCategory);

      if (index != -1) {

        currentCategoryIndex.value =
            index;
      }
    }

    _loadFavorites();
  }

  // =====================================================
  // CATEGORY NAVIGATION
  // =====================================================

  void nextCategory() {

    currentCategoryIndex.value =

        (currentCategoryIndex.value + 1)

            % categories.length;
  }

  void prevCategory() {

    currentCategoryIndex.value =

        (currentCategoryIndex.value - 1

            + categories.length)

            % categories.length;
  }

