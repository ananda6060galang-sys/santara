  // FAVORITES
  // =====================================================

  Future<void> _loadFavorites()
  async {

    for (final categoryRecipes
        in recipesByCategory.values) {

      for (final recipe
          in categoryRecipes) {

        final isFav =

            await isRecipeFavorited(
                recipe.title);

        favoriteCache[
            recipe.title] = isFav;
      }
    }
  }

  bool isFavorite(String title) =>

      favoriteCache[title]
          ?? false;

  Future<void>
      toggleFavoriteRecipe(
          RecipeModel recipe)
  async {

    final recipeData = {

      'id':
          recipe.id,

      'title':
          recipe.title,

      'imagePath':
          'assets/${recipe.imageUrl}',

      'location':
          recipe.location,

      'duration':
          '${recipe.cookingTime} menit',

      'description':
          recipe.description,
    };

    final result =
        await toggleFavorite(
            recipeData);

    favoriteCache[
        recipe.title] = result;

    Get.snackbar(

      '',

      result

          ? '${recipe.title} ditambahkan ke favorit'

          : '${recipe.title} dihapus dari favorit',

      snackPosition:
          SnackPosition.BOTTOM,

      backgroundColor:
          const Color(0xFF8B4513),

      colorText:
          const Color(0xFFFFFFFF),

      duration:
          const Duration(seconds: 2),

      titleText:
          const SizedBox.shrink(),
    );
  }

  // =====================================================
  // SHARE
  // =====================================================

  void shareRecipe(
      RecipeModel recipe) {

    final text = '''

🍽️ ${recipe.title}

📍 Lokasi:
${recipe.location}

⏱️ Waktu:
${recipe.cookingTime} menit

Bagikan resep nusantara favorit kamu! 🇮🇩

''';

    Share.share(

      text,

      subject:
          'Resep ${recipe.title} - Santara',
    );
  }
}
